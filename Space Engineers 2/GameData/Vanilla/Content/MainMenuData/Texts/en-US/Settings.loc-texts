{
  "DisclaimerOptionName": "Показывать отказ от ответственности при запуске",
  "DisclaimerOptionDescription": "Показывает отказ от ответственности о раннем доступе при запуске игры.",
  "EnableAutosaveOptionName": "Включить автосохранение",
  "EnableAutosaveOptionDescription": "При включении игра автоматически сохраняет ваш мир через регулярные интервалы.\n\nПримечание: Эта функция будет применяться только к вновь созданным сохранениям.",
  "GameModeOptionName": "Режим игры",
  "GameModeOptionDescription": "Позволяет переключаться между творческим режимом и режимом выживания.",
  "EnableSuperDampenersOptionName": "Супер-гасители",
  "EnableToastNotificationsOptionName": "Включить всплывающие уведомления",
  "EnableToastNotificationsOptionDescription": "Включает систему уведомлений, предоставляющую полезную информацию, например предупреждения о приближении к лимиту PCU.",
  "UIBackgroundOpacityOptionName": "Прозрачность фона интерфейса",
  "UIBackgroundOpacityOptionDescription": "Настраивает прозрачность внутриигровых меню, например экрана терминала.",
  "HideCrosshairWithUIOptionName": "Скрывать прицел вместе с HUD",
  "HideCrosshairWithUIOptionDescription": "При включении скрытие HUD {Control:ToggleUIVisibility} также скроет прицел. При отключении прицел остаётся видимым, даже когда HUD скрыт.",
  "PresetOptionsName": "Предустановка",
  "PresetOptionsDescription": "Выберите предустановку для автоматической настройки общего качества графики, балансируя производительность и визуальную детализацию в зависимости от возможностей вашей системы.\n\nЭкстремальная – оптимизирована для высокопроизводительного оборудования, превышающего рекомендуемые характеристики.\n\nВысокая – рекомендуется для систем, соответствующих рекомендуемым аппаратным требованиям.\n\nСредняя – подходит для систем, соответствующих минимальным требованиям.\n\nНизкая – для бюджетного или неподдерживаемого оборудования, где производительность важнее визуальных эффектов.",
  "ScalingModeOptionsName": "Режим масштабирования",
  "ScalingModeOptionsDescription": "Настраивает масштаб разрешения области просмотра мира без изменения размера интерфейса.",
  "TextureOptionsName": "Качество текстур",
  "TextureOptionsDescription": "Настраивает разрешение внутриигровых текстур. Более высокие настройки обеспечивают более чёткие и детализированные поверхности, но могут повлиять на производительность на слабых системах.",
  "SunShadowOptionsName": "Качество теней солнца",
  "LocalLightShadowOptionsName": "Качество теней локальных источников",
  "SunShadowOptionsDescription": "Регулирует резкость и детализацию теней солнца в игре. Более высокие настройки дают более реалистичные тени, но могут снизить производительность.",
  "LocalLightShadowOptionsDescription": "Регулирует резкость и детализацию локальных теней (теней от световых блоков, фонарика персонажа и т.д.) в игре. Более высокие настройки дают более реалистичные тени, но могут снизить производительность.",
  "LightingOptionsName": "Качество освещения",
  "LightingOptionsDescription": "Регулирует качество освещения. Более высокие настройки дают свету большую дальность и отображают его в большем количестве ситуаций, но могут снизить производительность.",
  "ParallaxOptionsName": "Качество карт параллакса",
  "ParallaxOptionsDescription": "Улучшает реалистичность текстур, добавляя глубину и детализацию теней без дополнительной геометрии. Более высокие настройки улучшают глубину поверхности, но могут повлиять на производительность.",
  "ArmorBevelOptionsName": "Сглаживание брони",
  "ArmorBevelOptionsDescription": "Включает или отключает сглаживание краёв брони для более полированного, округлого вида.",
  "TerrainOptionsName": "Качество местности",
  "TerrainOptionsDescription": "Регулирует детализацию и реалистичность местности, включая текстуры земли и ландшафтные особенности. Более высокие настройки улучшают визуальную детализацию, но могут повлиять на производительность.",
  "RenderingDistanceOptionName": "Дальность рендеринга",
  "RenderingDistanceOptionDescription": "Контролирует, как далеко игра рендерит объекты и местность. Более высокие настройки увеличивают видимую дальность, но могут снизить производительность.",
  "AntiAliasingOptionsName": "Режим сглаживания",
  "AntiAliasingOptionsDescription": "Выберите FXAA для более плавных краёв с минимальным влиянием на производительность (хотя может быть небольшое размытие), или FSR для повышения чёткости и частоты кадров. Используйте любой из них для баланса качества и производительности или отключите для нативного рендеринга.",
  "RaytracingOptionsName": "Трассировка лучей",
  "RaytracingOptionsDescription": "Включает реалистичное освещение, тени и отражения за счёт симуляции поведения света в реальном мире. Более высокие настройки улучшают визуальные эффекты, но могут снизить производительность.",
  "ParticlesOptionsName": "Качество частиц",
  "ParticlesOptionsDescription": "Регулирует визуальное качество эффектов частиц. Более высокие настройки улучшают визуальную детализацию, но могут снизить производительность.",
  "FoVSliderName": "Поле зрения",
  "FoVSliderDescription": "Регулирует, какая часть игрового мира видна. Более высокое поле зрения увеличивает периферийное зрение, но может искажать объекты. Более низкое поле зрения даёт более узкий фокус с меньшим движением на экране.",
  "AdapterOptionsName": "Видеоадаптер",
  "AdapterOptionsDescription": "Выберите, какой GPU использует игра. Рекомендуется использовать дискретный GPU для лучшей производительности и качества графики.\n\nТребуется перезапуск.",
  "ResolutionOptionsName": "Разрешение",
  "ResolutionOptionsDescription": "Устанавливает количество пикселей на экране. Более высокое разрешение даёт более чёткое изображение, но может снизить производительность.",
  "VSyncModeOptionsName": "Режим VSync",
  "VSyncModeOptionsDescription": "Предотвращает разрывы экрана за счёт синхронизации частоты кадров с частотой обновления монитора, что потенциально может снизить производительность.",
  "FullScreenOptionName": "Полноэкранный режим",
  "FullScreenOptionDescription": "Включает полноэкранный режим.",
  "AudioDeviceOptionsName": "Аудиоустройство",
  "AudioDevicesOptionsDescription": "Список доступных аудиоустройств.",
  "MasterBusOptionName": "Общий",
  "MasterBusOptionDescription": "Регулирует общую громкость в игре.\n\nПримечание: Значения выше 100 могут вызвать искажение звука.",
  "MusicBusOptionName": "Музыка",
  "MusicBusOptionDescription": "Регулирует громкость музыки в игре.\n\nПримечание: Значения выше 100 могут вызвать искажение звука.",
  "SFXBusOptionName": "Звуковые эффекты",
  "SFXBusOptionDescription": "Регулирует громкость звуковых эффектов в игре.\n\nПримечание: Значения выше 100 могут вызвать искажение звука.",
  "SystemAudioDeviceName": "Системное устройство по умолчанию",
  "UIBusOptionName": "Интерфейс",
  "UIBusOptionDescription": "Регулирует громкость интерфейса в игре.\n\nПримечание: Значения выше 100 могут вызвать искажение звука.",
  "SpeedometerUnitOptionName": "Единица спидометра",
  "SpeedometerUnitOptionDescription": "Определяет единицу измерения скорости, которая будет использоваться на спидометре.",
  "ShareContactInformationName": "Передавать контактную информацию",
  "ShareContactInformationDescription": "При создании отчёта об ошибке передаёт предоставленную пользователем информацию разработчикам, чтобы они могли связаться с вами для уточнения деталей события.",
  "ContactInformationName": "Контактные данные пользователя",
